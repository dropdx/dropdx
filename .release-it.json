{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  },
  "github": {
    "autogenerate": true,
    "releaseName": "v${version}",
    "tokenRef": "GITHUB_TOKEN"
  },
  "git": {
    "tagName": "v${version}",
    "commitMessage": "chore: release v${version}",
    "requireCleanWorkingDir": true,
    "push": true
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": [
      "sed -i \"s/var Version = \\\".*\\\"/var Version = \\\"v${version}\\\"/\" packages/cmd/version.go",
      "sed -i \"s/version: '.*'/version: '${version}'/\" snap/snapcraft.yaml",
      "pnpm recursive exec -- pnpm version ${version} --allow-same-version --no-git-tag-version"
    ]
  }
}
